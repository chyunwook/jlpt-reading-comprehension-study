# local.properties 예시 파일
# 이 파일을 local.properties로 복사한 후 실제 값을 입력하세요
# local.properties는 .gitignore에 포함되어 있어 git에 올라가지 않습니다

# Android SDK 경로 (Android Studio가 자동으로 설정)
sdk.dir=/path/to/your/Android/sdk

# OpenAI API Key
# https://platform.openai.com/api-keys 에서 발급받은 키를 입력하세요
OPENAI_API_KEY=sk-your-api-key-here
